{
  "manifest_version": 3,
  "name": "Tab Scheduler",
  "version": "1.2.0",
  "description": "Schedule tabs to reopen at a specific date and time with smart presets",
  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "notifications",
    "tabGroups"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
