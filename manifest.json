{
  "manifest_version": 3,
  "name": "Tab Scheduler",
  "version": "1.7.1",
  "description": "Schedule tabs to reopen at a specific date and time with smart presets",
  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "notifications",
    "tabGroups",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period",
        "mac": "Command+Shift+Period"
      },
      "description": "Open Tab Scheduler"
    },
    "quick-schedule-tomorrow": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Quick schedule for tomorrow 9am"
    },
    "quick-schedule-later": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Quick schedule for later today"
    }
  }
}
